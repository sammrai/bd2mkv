#!/bin/bash
# bd2mkv: Blu-ray rip + H.265 encode pipeline
#
# Pipeline (each step reads the previous step's output):
#   [1] rip                    disc           -> ./output/<DISC>/title_t*.mkv
#   [2] encode <folder> [crf]  ./output/<f>/* -> ./encoded/<f>/<f>.mkv (+ *-scene.mkv)
#   [3] name-chapters <folder> ./encoded/<f>/<f>.mkv  (in-place; uses mkvpropedit)
#       requires: ./encoded/<f>/setlist.txt; lyrics auto-fetched from j-lyric
#                 if `# @artist NAME` is on setlist.txt or `lyrics/` is pre-filled
#
# Usage:
#   bd2mkv                          # default = [1] + [2]
#   bd2mkv rip                      # [1] only — needs disc, fetches AACS keydb + MakeMKV beta key
#   bd2mkv encode <folder> [crf]    # [2] only — no disc, no keys; CRF default 20
#   bd2mkv name-chapters <folder>   # [3] only — no disc, no keys; MUTATES the mkv in place
set -euo pipefail

ensure_keydb() {
    local target="${HOME}/.MakeMKV/KEYDB.cfg"
    mkdir -p "$(dirname "$target")"
    if [ -f /work/aacs/keydb.cfg ]; then
        cp /work/aacs/keydb.cfg "$target"
        return
    fi
    mkdir -p "$(dirname "$KEYDB_CACHE")"
    if [ ! -s "$KEYDB_CACHE" ] || [ -z "$(find "$KEYDB_CACHE" -mtime -7 2>/dev/null)" ]; then
        echo "Downloading latest keydb.cfg..."
        curl -fsSL -o /tmp/keydb.zip "http://fvonline-db.bplaced.net/fv_download.php?lang=eng"
        unzip -p /tmp/keydb.zip > "$KEYDB_CACHE"
        rm /tmp/keydb.zip
    fi
    cp "$KEYDB_CACHE" "$target"
}

ensure_betakey() {
    mkdir -p "$(dirname "$BETAKEY_CACHE")" "${HOME}/.MakeMKV"
    if [ ! -s "$BETAKEY_CACHE" ] || [ -z "$(find "$BETAKEY_CACHE" -mtime -1 2>/dev/null)" ]; then
        echo "Fetching MakeMKV beta key..."
        local key
        key=$(curl -fsSL "https://www.makemkv.com/forum/viewtopic.php?t=1053" \
            | grep -oE 'T-[a-zA-Z0-9@_-]{60,}' | head -1 || true)
        [ -n "$key" ] && echo "$key" > "$BETAKEY_CACHE"
    fi
    if [ -s "$BETAKEY_CACHE" ]; then
        printf 'app_Key = "%s"\n' "$(cat "$BETAKEY_CACHE")" > "${HOME}/.MakeMKV/settings.conf"
    fi
}

cmd_rip() {
    ensure_keydb
    ensure_betakey

    echo "Reading disc..."
    local info name titles out
    info=$(makemkvcon -r info disc:0 2>&1)
    name=$(echo "$info" | grep -E "^DRV:0," | sed 's/.*","\([^"]*\)",".*/\1/')
    if [ -z "$name" ]; then
        name=$(echo "$info" | grep -E "^CINFO:2,0," | sed 's/CINFO:2,0,"//;s/"$//' || true)
    fi
    # Prefer richer name from BDMV/META/DL/bdmt_*.xml when MakeMKV returns the
    # generic volume label only (BD_ROM / DVD_ROM). For other labels we trust
    # the disc's self-reported value so re-rips collide and skip.
    case "$name" in
        ""|BD_ROM|DVD_ROM)
            local mnt bdmt raw
            mnt=$(mktemp -d)
            if mount -r /dev/sr0 "$mnt" 2>/dev/null; then
                bdmt=$(ls "$mnt"/BDMV/META/DL/bdmt_*.xml 2>/dev/null | head -1 || true)
                if [ -n "$bdmt" ]; then
                    raw=$(grep -oE '<di:name>[^<]+</di:name>' "$bdmt" | head -1 \
                          | sed 's|<[^>]*>||g' | tr -d '\n\r' || true)
                    if [ -n "$raw" ]; then
                        name=$(echo "$raw" | tr ' /\\:*?"<>|' '_' | tr -s '_')
                    fi
                fi
                umount "$mnt" 2>/dev/null || true
            fi
            rmdir "$mnt" 2>/dev/null || true
            ;;
    esac
    # Last-resort timestamp only when nothing was readable at all
    [ -z "$name" ] && name="disc_$(date +%Y%m%d_%H%M%S)"

    out="/work/output/$name"
    mkdir -p "$out"
    echo "Disc: $name"

    titles=$(echo "$info" | grep -E "^TINFO:[0-9]+," | sed 's/TINFO:\([0-9]*\),.*/\1/' | sort -nu)
    [ -z "$titles" ] && { echo "No titles found on disc."; exit 1; }

    for t in $titles; do
        local pat
        pat=$(printf "_t%02d.mkv" "$t")
        if compgen -G "$out/*$pat" > /dev/null; then
            echo "Skip title $t (already ripped)"
            continue
        fi
        echo "=== Ripping title $t ==="
        makemkvcon mkv "disc:0" "$t" "$out" --progress=-stdout
    done

    echo "$name" > /tmp/last-disc
    echo "Done: $out"
}

cmd_encode() {
    local input="${1:-}" crf="${2:-20}"
    if [ -z "$input" ] && [ -f /tmp/last-disc ]; then
        input="/work/output/$(cat /tmp/last-disc)"
    fi
    [ -z "$input" ] && { echo "Usage: bd2mkv encode <folder> [crf]"; exit 1; }
    [ -d "$input" ] || { echo "Not a directory: $input"; exit 1; }

    local name out main
    name=$(basename "$input")
    out="/work/encoded/$name"
    mkdir -p "$out"
    main=$(basename "$(ls -S "$input"/*.mkv 2>/dev/null | head -1)")

    for f in "$input"/*.mkv; do
        [ -f "$f" ] || continue
        local fn target
        fn=$(basename "$f")
        if [ "$fn" = "$main" ]; then
            target="$out/$name.mkv"
        else
            target="$out/${fn%.mkv}-scene.mkv"
        fi
        if [ -f "$target" ]; then
            echo "Skip (exists): $(basename "$target")"
            continue
        fi
        echo "Encoding $fn -> $(basename "$target")"
        ffmpeg -hide_banner -loglevel error -stats -i "$f" \
            -map 0:v -map 0:a -map 0:s? -map_chapters 0 \
            -c:v libx265 -crf "$crf" -preset medium \
            -c:a aac -b:a 320k \
            -c:s copy \
            "$target"
    done
    echo "Done: $out"
}

cmd_fetch_lyrics() {
    local folder="${1:?Usage: bd2mkv fetch-lyrics <encoded_folder> [artist]}"
    local artist="${2:-}"
    folder=$(realpath "$folder")
    local setlist="$folder/setlist.txt"
    local lyrics_dir="$folder/lyrics"
    local lib="${BD2MKV_LIB:-/usr/local/lib/bd2mkv}"

    [ -f "$setlist" ] || { echo "Missing: $setlist"; exit 1; }

    local args=(--setlist "$setlist" --lyrics-dir "$lyrics_dir")
    [ -n "$artist" ] && args+=(--artist "$artist")
    python3 "$lib/fetch_lyrics.py" "${args[@]}"
}

cmd_name_chapters() {
    local folder="${1:?Usage: bd2mkv name-chapters <encoded_folder>}"
    folder=$(realpath "$folder")
    local name="$(basename "$folder")"
    local mkv="$folder/$name.mkv"
    local setlist="$folder/setlist.txt"
    local lyrics="$folder/lyrics"
    local work="$folder/.chapters_cache"
    local lib="${BD2MKV_LIB:-/usr/local/lib/bd2mkv}"

    [ -f "$mkv" ]      || { echo "Missing: $mkv"; exit 1; }
    [ -f "$setlist" ]  || { echo "Missing: $setlist"; exit 1; }

    # auto-fetch lyrics if missing/empty (requires `# @artist NAME` in setlist.txt)
    if [ ! -d "$lyrics" ] || [ -z "$(ls -A "$lyrics" 2>/dev/null)" ]; then
        echo "[0/5] fetching lyrics from j-lyric"
        python3 "$lib/fetch_lyrics.py" --setlist "$setlist" --lyrics-dir "$lyrics" || {
            echo "lyrics fetch failed; either add lyrics manually to $lyrics or"
            echo "add '# @artist NAME' to $setlist or run 'bd2mkv fetch-lyrics <folder> <artist>'"
            exit 1
        }
    fi

    mkdir -p "$work/snippets" "$work/transcripts" "$WHISPER_CACHE"

    echo "[1/5] reading chapter timeline"
    ffprobe -v error -show_chapters -of csv=p=0 "$mkv" \
        | awk -F, 'BEGIN{print "idx,start,end,duration"} {printf "%d,%s,%s,%.6f\n", NR, $4, $6, $6-$4}' \
        > "$work/chapters.csv"

    echo "[2/5] extracting audio snippets"
    tail -n +2 "$work/chapters.csv" | while IFS=, read idx start end dur; do
        local snippet_dur out
        snippet_dur=$(awk -v d="$dur" 'BEGIN{print (d<90?d:90)}')
        out="$work/snippets/ch$(printf '%02d' $idx).mp3"
        [ -f "$out" ] && continue
        ffmpeg -nostdin -hide_banner -loglevel error \
            -ss "$start" -t "$snippet_dur" -i "$mkv" \
            -vn -ac 1 -ar 16000 -b:a 64k \
            "$out"
    done

    echo "[3/5] transcribing (medium → large-v3 retry)"
    INPUT_DIR="$work/snippets" \
    OUTPUT_DIR="$work/transcripts" \
    WHISPER_CACHE="$WHISPER_CACHE" \
        python3 "$lib/transcribe.py"

    echo "[4/5] matching transcripts to setlist"
    python3 "$lib/match_chapters.py" \
        --chapters    "$work/chapters.csv" \
        --setlist     "$setlist" \
        --lyrics      "$lyrics" \
        --transcripts "$work/transcripts" \
        --report      "$work/match_report.tsv" \
        > "$work/assignment.tsv"
    head -40 "$work/match_report.tsv" | column -t -s $'\t' || true

    echo "[5/5] applying chapter names"
    python3 "$lib/build_chapters_xml.py" \
        --chapters   "$work/chapters.csv" \
        --assignment "$work/assignment.tsv" \
        > "$folder/chapters.xml"
    mkvpropedit "$mkv" --chapters "$folder/chapters.xml"
    echo "Done: $folder/chapters.xml"
}

cmd="${1:-all}"
[ $# -gt 0 ] && shift
case "$cmd" in
    rip)            cmd_rip ;;
    encode)         cmd_encode "$@" ;;
    name-chapters)  cmd_name_chapters "$@" ;;
    fetch-lyrics)   cmd_fetch_lyrics "$@" ;;
    all)            cmd_rip && cmd_encode ;;
    -h|--help|help) sed -n '2,14p' "$0" | sed 's/^# \?//' ;;
    *) echo "Unknown command: $cmd"; exit 1 ;;
esac
